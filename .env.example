# Copy this file to `.env` for local development:  cp .env.example .env
# Local dev uses SQLite (zero setup). For production (PostgreSQL on a VPS) see
# .env.production.example and DEPLOYMENT.md.

# --- Database ---
DATABASE_URL="file:./dev.db"

# --- Auth ---
# Change to a long random string. Generate one with:  openssl rand -base64 48
AUTH_SECRET="dev-only-secret-change-me-to-a-long-random-string-please"
# Inactivity timeout (Section 7.7): auto-logout after this many idle minutes.
# The window slides while the user is active. Default 30.
SESSION_IDLE_MINUTES="30"

# --- Integrations (Section 7.10) — optional; unset = simulation mode ---
# Email (SMTP)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="you@thesfedu.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM="theSFedu <you@thesfedu.com>"
# WhatsApp Business Cloud API (Meta)
# WHATSAPP_TOKEN=""
# WHATSAPP_PHONE_ID=""
# Two-way receive (Section 7.1): set a verify token for the webhook handshake, and
# optionally the app secret to enforce signature validation on inbound events.
# WHATSAPP_VERIFY_TOKEN=""
# WHATSAPP_APP_SECRET=""
# SMS (generic HTTP gateway)
# SMS_API_URL=""
# SMS_API_KEY=""
# SMS_SENDER="SFEDU"
# Facebook/Instagram Lead Ads ingestion (Section 7.10). Webhook at
# /api/integrations/leadforms/webhook. PAGE_TOKEN fetches field data from Graph.
# BRANCH_CODE / VERTICAL set routing defaults for captured leads.
# LEADFORM_VERIFY_TOKEN=""
# LEADFORM_PAGE_TOKEN=""
# LEADFORM_APP_SECRET=""
# LEADFORM_BRANCH_CODE=""
# LEADFORM_VERTICAL="B2C_DIRECT"
# Payment gateway (Razorpay)
# RAZORPAY_KEY_ID=""
# RAZORPAY_KEY_SECRET=""
# RAZORPAY_WEBHOOK_SECRET=""

# --- Security (Section 7.11) — optional ---
# MANAGEMENT_IP_WHITELIST=""

# --- Scheduled report digests (Section 6.7) ---
CRON_SECRET="dev-cron-secret-change-me"
