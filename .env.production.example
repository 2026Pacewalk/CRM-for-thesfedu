# Copy to `.env` on the VPS and fill in real values. Never commit the real .env.

# --- PostgreSQL (used by docker-compose) ---
POSTGRES_USER=sfedu
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=thesfedu_crm

# --- Auth ---
# Generate a long random secret, e.g.:  openssl rand -base64 48
AUTH_SECRET=change-me-to-a-long-random-string

# NOTE: The app's DATABASE_URL is assembled automatically in docker-compose.yml
# from the POSTGRES_* values above. If you run the app WITHOUT Docker, set
# DATABASE_URL yourself, e.g.:
# DATABASE_URL=postgresql://sfedu:password@localhost:5432/thesfedu_crm?schema=public

# --- Integrations (Section 7.10) — optional ---
# Leave unset to run a channel in SIMULATION mode (rendered + logged, not sent).
# Email (SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@thesfedu.com
# SMTP_PASS=your-app-password
# SMTP_FROM=theSFedu <you@thesfedu.com>
# WhatsApp Business Cloud API (Meta)
# WHATSAPP_TOKEN=EAAG...
# WHATSAPP_PHONE_ID=1234567890
# SMS (generic HTTP gateway: JSON POST { to, message, sender }, Bearer auth)
# SMS_API_URL=https://api.your-sms-gateway.com/send
# SMS_API_KEY=your-key
# SMS_SENDER=SFEDU
# Payment gateway (Razorpay)
# RAZORPAY_KEY_ID=rzp_live_xxx
# RAZORPAY_KEY_SECRET=your-secret
# RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
